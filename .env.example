# ============================================================
# MANS 环境变量配置模板
# 复制此文件为 .env 并填入实际值
# ============================================================

# --------------------------------------------------------
# 环境配置
# --------------------------------------------------------
ENV=development
DEBUG=true

# --------------------------------------------------------
# 服务配置
# --------------------------------------------------------
HOST=127.0.0.1
PORT=666

# --------------------------------------------------------
# 当前激活的 Provider
# 可选: doubao / qwen / glm / openai
# 根据此选择决定使用哪个 Provider 的模型配置
# --------------------------------------------------------
ACTIVE_PROVIDER=doubao

# --------------------------------------------------------
# 豆包配置
# 获取 API Key: https://console.volcengine.com/ark/
# --------------------------------------------------------
DOUBAO_API_KEY=your_doubao_api_key_here
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# 豆包模型ID（根据分工选择）
DOUBAO_WRITER_MODEL=doubao-pro-128k      # 正文生成：最高质量
DOUBAO_GENERATOR_MODEL=doubao-pro-128k   # 初始化生成：最高质量
DOUBAO_TRIM_MODEL=doubao-lite-32k        # 上下文裁剪：快速经济
DOUBAO_EXTRACT_MODEL=doubao-pro-32k      # 状态提取：平衡质量与速度
DOUBAO_EMBED_MODEL=doubao-embedding      # 文本向量化

# --------------------------------------------------------
# Qwen 配置（预留扩展）
# 获取 API Key: https://dashscope.aliyun.com/
# --------------------------------------------------------
QWEN_API_KEY=your_qwen_api_key_here
QWEN_BASE_URL=https://dashscope.aliyuncs.com/api/v1

# Qwen模型ID（预留扩展）
QWEN_WRITER_MODEL=qwen-max               # 正文生成
QWEN_GENERATOR_MODEL=qwen-max            # 初始化生成
QWEN_TRIM_MODEL=qwen-turbo               # 上下文裁剪
QWEN_EXTRACT_MODEL=qwen-plus             # 状态提取
QWEN_EMBED_MODEL=text-embedding-v3       # 文本向量化

# --------------------------------------------------------
# GLM 配置（预留扩展）
# 获取 API Key: https://open.bigmodel.cn/
# --------------------------------------------------------
GLM_API_KEY=your_glm_api_key_here
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# GLM模型ID（预留扩展）
GLM_WRITER_MODEL=glm-4                   # 正文生成
GLM_GENERATOR_MODEL=glm-4                # 初始化生成
GLM_TRIM_MODEL=glm-4-flash               # 上下文裁剪
GLM_EXTRACT_MODEL=glm-4-air              # 状态提取
GLM_EMBED_MODEL=embedding-3              # 文本向量化

# --------------------------------------------------------
# OpenAI 配置（预留扩展）
# --------------------------------------------------------
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=

# OpenAI模型ID（预留扩展）
OPENAI_WRITER_MODEL=gpt-4o               # 正文生成
OPENAI_GENERATOR_MODEL=gpt-4o            # 初始化生成
OPENAI_TRIM_MODEL=gpt-4o-mini            # 上下文裁剪
OPENAI_EXTRACT_MODEL=gpt-4o              # 状态提取
OPENAI_EMBED_MODEL=text-embedding-3-small # 文本向量化

# --------------------------------------------------------
# Token 预算配置
# --------------------------------------------------------
INJECTION_TOKEN_BUDGET=3500     # Injection Engine 总预算
INJECTION_MAX_CHARACTERS=3      # 最大出场人物数
INJECTION_MAX_FORESHADOWING=2   # 最大激活伏笔数
WRITER_MAX_TOKENS=3000          # Writer 单次最大生成 token

# --------------------------------------------------------
# 存储路径配置
# --------------------------------------------------------
WORKSPACE_PATH=workspace
VECTOR_STORE_TYPE=chromadb

# --------------------------------------------------------
# 功能开关
# --------------------------------------------------------
ENABLE_STREAMING=true
ENABLE_ASYNC_UPDATE=true
ENABLE_VECTOR_SEARCH=true

# --------------------------------------------------------
# 日志配置
# --------------------------------------------------------
LOG_LEVEL=INFO
# LOG_FILE=logs/mans.log
