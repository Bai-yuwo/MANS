# ============================================================
# MANS 环境变量配置模板（17-Agent 新架构）
# 复制此文件为 .env 并填入实际值
# ============================================================

# --------------------------------------------------------
# 基础服务
# --------------------------------------------------------
ENV=development
DEBUG=true
HOST=127.0.0.1
PORT=666

# --------------------------------------------------------
# ARK Provider（新架构唯一 Provider）
# 获取 API Key: https://console.volcengine.com/ark/
# --------------------------------------------------------
ARK_API_KEY=
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_EMBED_MODEL=              # 可选，留空使用默认

# 向后兼容：若上方 ARK_* 未设置，会 fallback 到 DOUBAO_*
DOUBAO_API_KEY=
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# --------------------------------------------------------
# Agent 模型精细覆盖（可选，留空则使用 ROLE_DEFAULTS 默认值）
#
# 命名规则: {AGENT_NAME_UPPER}_MODEL / _TEMP / _MAX_TOKENS
# 例如: WRITER_MODEL=glm-4-7-251222
#
# 三档默认（代码内定义，无需在 .env 重复）:
#   creator   (Writer) : glm-4-7-251222    / 0.7 / 3000
#   generator (世界观等): deepseek-v3-2-251201 / 0.4 / 8000
#   reviewer  (审查/调度): doubao-seed-2-0-pro-260215 / 0.15 / 4000
# --------------------------------------------------------

# 创作档（唯一流式专家，正文生成）
WRITER_MODEL=
WRITER_TEMP=
WRITER_MAX_TOKENS=

# 审查/调度档（Director、SceneShowrunner）
DIRECTOR_MODEL=
DIRECTOR_TEMP=
DIRECTOR_MAX_TOKENS=
SCENESHOWRUNNER_MODEL=
SCENESHOWRUNNER_TEMP=
SCENESHOWRUNNER_MAX_TOKENS=

# 生成档（世界观、角色、大纲）
WORLDARCHITECT_MODEL=
WORLDARCHITECT_TEMP=
WORLDARCHITECT_MAX_TOKENS=
PLOTARCHITECT_MODEL=
PLOTARCHITECT_TEMP=
PLOTARCHITECT_MAX_TOKENS=
CASTINGDIRECTOR_MODEL=
CASTINGDIRECTOR_TEMP=
CASTINGDIRECTOR_MAX_TOKENS=

# 专家档（Geographer, RuleSmith, PortraitDesigner, RelationDesigner,
#         ArcDesigner, ChapterDesigner, SceneDirector, Critic,
#         ContinuityChecker, ReviewManager, Scribe）
# 命名同上，例如: GEOGRAPHER_MODEL=...

# --------------------------------------------------------
# 存储路径
# --------------------------------------------------------
WORKSPACE_PATH=workspace
VECTOR_STORE_TYPE=chromadb

# --------------------------------------------------------
# 向量模型
# --------------------------------------------------------
VECTOR_MODEL_SOURCE=local
LOCAL_EMBED_MODEL=bge-m3
LOCAL_EMBED_CACHE_DIR=.cache

# --------------------------------------------------------
# 功能开关
# --------------------------------------------------------
ENABLE_STREAMING=true
ENABLE_ASYNC_UPDATE=true
ENABLE_VECTOR_SEARCH=true

# --------------------------------------------------------
# 日志
# --------------------------------------------------------
LOG_LEVEL=INFO
# LOG_FILE=logs/mans.log

# --------------------------------------------------------
# [DEPRECATED] 旧字段（backward-compat，新代码不再使用）
# 保留仅为防止旧脚本报错，后续将移除。
# --------------------------------------------------------
INJECTION_TOKEN_BUDGET=3500
INJECTION_MAX_CHARACTERS=3
INJECTION_MAX_FORESHADOWING=2
WRITER_MAX_TOKENS=3000
GENERATOR_MAX_TOKENS=8000
TRIM_MAX_TOKENS=2000
EXTRACT_MAX_TOKENS=2000
